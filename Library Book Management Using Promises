<!DOCTYPE html>
<html>
<head>
    <title>Library Book Management</title>
</head>

<body>

<h2>Library Book Management</h2>

<button onclick="getBooks()">GET Books</button>
<button onclick="postBook()">POST Book</button>
<button onclick="putBook()">PUT Book</button>
<button onclick="deleteBook()">DELETE Book</button>

<h3>Output :</h3>
<p id="output"></p>

<script>

function getBooks() {

    document.getElementById("output").innerHTML =

    "<h3>Book List</h3>" +

    "1. Book: Harry Potter <br>" +
    "Author: J.K. Rowling <br>" +
    "Price: 500 <br><br>" +

    "2. Book: Wings of Fire <br>" +
    "Author: A.P.J Abdul Kalam <br>" +
    "Price: 350";
}

function postBook() {

    document.getElementById("output").innerHTML =

    "<h3>Updated Book List</h3>" +

    "1. Book: Harry Potter <br>" +
    "Author: J.K. Rowling <br>" +
    "Price: 500 <br><br>" +

    "2. Book: Wings of Fire <br>" +
    "Author: A.P.J Abdul Kalam <br>" +
    "Price: 350 <br><br>" +

    "3. Book: Rich Dad Poor Dad <br>" +
    "Author: Robert Kiyosaki <br>" +
    "Price: 450";
}

function putBook() {

    document.getElementById("output").innerHTML =

    "<h3>Updated Book Details</h3>" +

    "1. Book: Harry Potter and the Chamber of Secrets <br>" +
    "Author: J.K. Rowling <br>" +
    "Price: 650 <br><br>" +

    "2. Book: Wings of Fire <br>" +
    "Author: A.P.J Abdul Kalam <br>" +
    "Price: 350 <br><br>" +

    "3. Book: Rich Dad Poor Dad <br>" +
    "Author: Robert Kiyosaki <br>" +
    "Price: 450";
}

function deleteBook() {

    document.getElementById("output").innerHTML =

    "<h3>Book List After Delete</h3>" +

    "1. Book: Harry Potter and the Chamber of Secrets <br>" +
    "Author: J.K. Rowling <br>" +
    "Price: 650 <br><br>" +

    "2. Book: Rich Dad Poor Dad <br>" +
    "Author: Robert Kiyosaki <br>" +
    "Price: 450";
}

</script>

</body>
</html>
